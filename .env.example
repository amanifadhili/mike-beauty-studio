# ─────────────────────────────────────────────────────────────────
# Mike Beauty Studio — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mike_beauty_studio?sslmode=require"

# ── NEXT AUTH (Auth.js v5) ────────────────────────────────────────
# Generate a secret: npx auth secret   OR   openssl rand -base64 32
AUTH_SECRET="your-super-secret-random-string-here"

# The canonical URL of your deployment (no trailing slash)
# Development:   http://localhost:3000
# Production:    https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# ── SEED / SETUP ──────────────────────────────────────────────────
# Credentials used when running: npx prisma db seed
# Change these before seeding a production database!
ADMIN_EMAIL="admin@mikebeautystudio.com"
ADMIN_PASSWORD="Password123!"

# ── APP (optional overrides) ──────────────────────────────────────
# Next.js environment — "development" | "production" | "test"
NODE_ENV="development"

# ── PRISMA / DEPLOYMENT SPECIFIC ──────────────────────────────────
# Force Prisma to use the binary engine if required by your host
PRISMA_CLIENT_ENGINE_TYPE="binary"

# Alternative generic database URL variable (often used by Vercel)
DATABASE_POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/mike_beauty_studio?sslmode=require"
