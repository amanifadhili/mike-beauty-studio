// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NATIVE ENUMS ───────────────────────────────────────────────────────────
enum Role {
  ADMIN
  WORKER
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CREDIT
}

enum TransactionSource {
  BOOKING
  WALK_IN
}

enum BookingStatus {
  NEW
  CONTACTED
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  CONVERTED
}

enum ExpenseCategory {
  RENT
  SUPPLIES
  MAINTENANCE
  UTILITIES
  MARKETING // Added MARKETING
  WORKER_PAYOUT
  OTHER
}

enum CreditStatus {
  PENDING
  CLEARED
}

enum AdvanceStatus {
  PENDING
  DEDUCTED
}

// ── CORE MODELS ────────────────────────────────────────────────────────────

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     Role   @default(ADMIN)

  // Formerly "Worker" properties ported natively for 1:1 deduplication
  phone          String?
  roleTitle      String? // e.g., "Lash Technician", "Receptionist"
  commissionType CommissionType @default(PERCENTAGE)
  commissionRate Int            @default(0) // Percentage (e.g., 40 for 40%) or Fixed amount
  status         UserStatus     @default(ACTIVE)
  balance        Int            @default(0) // Unpaid earnings balance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  transactions Transaction[]
  payments     WorkerPayment[]
  advances     WorkerAdvance[]
  services     Service[] // Many-to-many: Users qualified to perform specific services
  auditLogs    AuditLog[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  email     String? // Useful for future marketing additions
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings     Booking[]
  transactions Transaction[]
  credits      ClientCredit[]
}

// ── SERVICES & BOOKINGS ────────────────────────────────────────────────────

model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0) // For manual sorting in the UI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]
}

model Service {
  id          String   @id @default(uuid())
  name        String
  price       Int // Storing in smallest currency unit (e.g. RWF)
  description String
  duration    String // e.g. "2 hours"
  active      Boolean  @default(true)
  categoryId  String? // Optional relation to a category
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  workers      User[] // Many-to-many: Staff qualified to perform this service
  medias       Media[]
  bookings     Booking[]
  transactions Transaction[]
}

model Media {
  id        String   @id @default(uuid())
  url       String
  type      String // "image" or "video"
  category  String? // Optional category e.g. "Classic", "Volume"
  serviceId String?
  createdAt DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model Booking {
  id            String        @id @default(uuid())
  clientId      String
  preferredDate DateTime
  preferredTime String
  depositPaid   Int           @default(0) // Tracks prepaid booking fees
  notes         String?
  status        BookingStatus @default(NEW)
  serviceId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  transactions Transaction[] // A booking can result in a transaction
}

// ── FINANCIAL LEDGERS ──────────────────────────────────────────────────────

model Transaction {
  id        String  @id @default(uuid())
  clientId  String
  serviceId String
  userId    String // The staff member who performed the service
  bookingId String? // Optional: Null if it's a walk-in

  price            Int // Actual price charged
  workerCommission Int // Calculated block for the worker
  salonShare       Int // Calculated block for the salon

  paymentMethod PaymentMethod
  source        TransactionSource
  date          DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  worker  User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  credits ClientCredit[]
}

model Expense {
  id        String          @id @default(uuid())
  title     String
  amount    Int
  category  ExpenseCategory
  date      DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  payments WorkerPayment[] // Establishing the explicit ledger tie
}

model WorkerPayment {
  id        String   @id @default(uuid())
  userId    String
  expenseId String // Orphan prevention reference
  amount    Int // Total amount paid out
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  worker  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Restrict)
}

model WorkerAdvance {
  id        String        @id @default(uuid())
  userId    String
  amount    Int
  date      DateTime      @default(now())
  status    AdvanceStatus @default(PENDING)
  createdAt DateTime      @default(now())

  worker User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientCredit {
  id             String       @id @default(uuid())
  transactionId  String       @unique // 1-to-1 relation with Transaction
  clientId       String
  originalAmount Int
  paidAmount     Int          @default(0)
  status         CreditStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ── SYSTEM & AUDIT ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String // The admin/user who performed the action
  action     String // e.g. "CREATE_TRANSACTION", "UPDATE_EXPENSE", "PAY_WORKER"
  targetId   String? // ID of the record that was modified
  targetType String? // e.g. "Transaction", "Expense"
  details    String // JSON stringified details of the change
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model Review {
  id        String   @id @default(uuid())
  name      String
  rating    Int // 1-5
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AppSetting {
  key       String   @id // e.g., "WHATSAPP_NUMBER", "STUDIO_ADDRESS"
  value     String
  category  String // 'GENERAL', 'BOOKING', 'SOCIAL'
  updatedAt DateTime @updatedAt
}
