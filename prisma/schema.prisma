// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // For future RBAC
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  name        String
  price       Int      // Storing in smallest currency unit (e.g. RWF)
  description String
  duration    String   // e.g. "2 hours"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  medias    Media[]
  bookings  Booking[]
}

model Media {
  id        String   @id @default(uuid())
  url       String
  type      String   // "image" or "video"
  category  String?  // Optional category e.g. "Classic", "Volume"
  serviceId String?
  createdAt DateTime @default(now())

  service   Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
}

model Booking {
  id            String   @id @default(uuid())
  name          String
  phone         String
  preferredDate DateTime
  preferredTime String
  notes         String?
  status        String   @default("NEW") // "NEW", "CONTACTED", "SCHEDULED", "COMPLETED", "CANCELLED"
  serviceId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  name      String
  rating    Int      // 1-5
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

